rules_version = '2';

// ============================================================
//  RÈGLES DE SÉCURITÉ FIRESTORE — Une tier list par utilisateur
//  À copier-coller dans : Console Firebase → Firestore Database
//  → onglet "Règles" (Rules) → Publier.
//
//  boards/{uid} : la tier list complète d'un utilisateur
//    - LECTURE : tous les connectés (pour la galerie commune)
//    - ÉCRITURE : uniquement le propriétaire (uid == son compte)
// ============================================================
service cloud.firestore {
  match /databases/{database}/documents {

    match /boards/{userId} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth != null
                                    && request.auth.uid == userId;
    }

    // Tout le reste est verrouillé
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
