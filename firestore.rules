rules_version = '2';

// ============================================================
//  RÈGLES DE SÉCURITÉ FIRESTORE
//  À copier-coller dans : Console Firebase → Firestore Database
//  → onglet "Règles" (Rules) → Publier.
//
//  boards/{uid}  : la tier list complète d'un utilisateur
//    - LECTURE : tous les connectés (galerie commune)
//    - ÉCRITURE : uniquement le propriétaire
//
//  users/{uid}   : profil public léger (pseudo, filière, orientation,
//                  liste des personnes suivies)
//    - LECTURE : tous les connectés (filtres des stats, galerie)
//    - ÉCRITURE : uniquement le propriétaire
//
//  catalog/main  : catalogue partagé (filières, orientations,
//                  branches canoniques + correspondances)
//    - LECTURE / ÉCRITURE : tous les connectés (communauté de
//      confiance — même modèle collaboratif que les propositions)
//
//  comments/{id} : commentaires sur un prof
//    - CRÉATION : auteur authentifié, texte 2–500 caractères,
//      ANTI-SPAM : 1 commentaire / 15 s imposé côté serveur — le
//      batch d'écriture doit mettre à jour users/{uid}.lastCommentAt,
//      comparé à l'horodatage du commentaire précédent.
//    - MODIF : l'auteur, OU n'importe qui si SEUL le champ
//      "reactions" change (réactions emoji des autres).
//    - SUPPRESSION : l'auteur uniquement.
//
//  reactions/{key} : réactions rapides sur un prof { emoji: [uid] }
//  activity/{id}   : fil d'activité, append-only (pas de modif/suppr.)
//
//  scores/{uid}    : leaderboard des mini-jeux (distinct des profs)
//    - ÉCRITURE : propriétaire, types vérifiés. Limite assumée : le
//      score est calculé côté client (pas de serveur de jeu).
// ============================================================
service cloud.firestore {
  match /databases/{database}/documents {

    function authed() { return request.auth != null; }
    function isOwner(userId) { return authed() && request.auth.uid == userId; }

    match /boards/{userId} {
      allow read: if authed();
      allow create, update, delete: if isOwner(userId);
    }

    match /users/{userId} {
      allow read: if authed();
      allow create, update, delete: if isOwner(userId);
    }

    match /catalog/{docId} {
      allow read, write: if authed();
    }

    match /comments/{commentId} {
      allow read: if authed();
      allow create: if authed()
        && request.resource.data.authorUid == request.auth.uid
        && request.resource.data.text is string
        && request.resource.data.text.size() >= 2
        && request.resource.data.text.size() <= 500
        && request.resource.data.createdAt == request.time
        // Anti-spam : le batch doit poser users/{uid}.lastCommentAt = maintenant…
        && getAfter(/databases/$(database)/documents/users/$(request.auth.uid))
             .data.lastCommentAt == request.time
        // …et le commentaire précédent doit dater d'au moins 15 s.
        && (!exists(/databases/$(database)/documents/users/$(request.auth.uid))
            || !("lastCommentAt" in get(/databases/$(database)/documents/users/$(request.auth.uid)).data)
            || request.time > get(/databases/$(database)/documents/users/$(request.auth.uid))
                                .data.lastCommentAt + duration.value(15, 's'));
      allow update: if authed() && (
        resource.data.authorUid == request.auth.uid
        // Réactions des autres : seul le champ "reactions" peut changer
        || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions'])
      );
      allow delete: if authed() && resource.data.authorUid == request.auth.uid;
    }

    match /reactions/{key} {
      allow read, write: if authed();
    }

    match /scores/{userId} {
      allow read: if authed();
      allow create, update: if isOwner(userId)
        && request.resource.data.best is number
        && request.resource.data.total is number
        && request.resource.data.games is number;
      allow delete: if isOwner(userId);
    }

    match /activity/{id} {
      allow read: if authed();
      allow create: if authed()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.text is string
        && request.resource.data.text.size() <= 200;
      allow update, delete: if false;
    }

    // Tout le reste est verrouillé
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
