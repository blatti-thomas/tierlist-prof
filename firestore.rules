rules_version = '2';

// ============================================================
//  RÈGLES DE SÉCURITÉ FIRESTORE
//  À copier-coller dans : Console Firebase → Firestore Database
//  → onglet "Règles" (Rules) → Publier.
//
//  Principe : seules les personnes CONNECTÉES (ayant le mot de passe)
//  peuvent lire et écrire la tier list. Le reste est interdit.
// ============================================================
service cloud.firestore {
  match /databases/{database}/documents {

    // Le document unique de la tier list (tierlists/main)
    match /tierlists/{docId} {
      allow read, write: if request.auth != null;
    }

    // Tout le reste est verrouillé par défaut
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
